---
import BaseLayout from '../../layouts/BaseLayout.astro';

// D0 Product Updates — What's New
// Add product releases here as they ship
const changelog: Array<{version: string; date: string; type: string; title: string; items: string[]}> = [
  // {
  //   version: 'v0.1.0',
  //   date: '2026-XX-XX',
  //   type: 'major',
  //   title: 'D0 Private Beta Launch',
  //   items: [
  //     'Feature 1',
  //     'Feature 2',
  //   ],
  // },
];
---
<BaseLayout title="What's New — D0" description="D0 product updates, new features, and release notes.">

<section class="page-hero">
  <div class="section-label" data-i18n="updates.label">WHAT'S NEW</div>
  <h1 class="page-title" data-i18n="updates.title">Product Updates</h1>
  <p class="page-desc" data-i18n="updates.desc">D0 产品更新、新功能与版本发布记录。</p>
</section>

{changelog.length > 0 ? (
  <section class="changelog-section">
    {changelog.map(entry => (
      <div class="entry">
        <div class="entry-meta">
          <div class={`entry-type type-${entry.type}`}>{entry.type.toUpperCase()}</div>
          <div class="entry-version">{entry.version}</div>
          <div class="entry-date">{entry.date}</div>
        </div>
        <div class="entry-body">
          <h2 class="entry-title">{entry.title}</h2>
          <ul class="entry-items">
            {entry.items.map(item => (
              <li class="entry-item">
                <span class="item-dot">·</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </section>
) : (
  <section class="empty-section">
    <div class="empty-inner">
      <div class="empty-icon">🚀</div>
      <h2 class="empty-title">D0 Private Beta is live.</h2>
      <p class="empty-desc">Product updates will appear here as new features ship.<br>Stay tuned.</p>
    </div>
  </section>
)}

</BaseLayout>

<style>
.page-hero { max-width: var(--max-w); margin: 0 auto; padding: 64px 24px 40px; }
.page-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(18px, 3vw, 28px);
  color: var(--text);
  margin: 8px 0 16px;
  line-height: 1.5;
}
.page-desc { font-size: 14px; color: var(--text2); line-height: 1.8; }

.section-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 8px;
}

.changelog-section {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px 80px;
  display: flex;
  flex-direction: column;
  gap: 0;
  border-left: 2px solid var(--border);
  margin-left: calc(24px + 80px);
  position: relative;
}

@media (max-width: 600px) {
  .changelog-section { margin-left: 24px; }
}

.entry {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 32px;
  padding: 32px 0 32px 32px;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.entry::before {
  content: '';
  position: absolute;
  left: -7px;
  top: 38px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
}

@media (max-width: 600px) {
  .entry { grid-template-columns: 1fr; gap: 12px; }
}

.entry-meta { display: flex; flex-direction: column; gap: 6px; padding-top: 2px; }
.entry-type {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 3px 8px;
  border-radius: 3px;
  width: fit-content;
}
.type-major { color: var(--accent); background: rgba(172,170,255,0.12); }
.type-content { color: var(--gold); background: rgba(232,184,78,0.1); }
.type-fix { color: var(--green); background: rgba(6,151,66,0.1); }

.entry-version {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}
.entry-date {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
}
.entry-title { font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 14px; }
.entry-items { display: flex; flex-direction: column; gap: 8px; list-style: none; }
.entry-item { display: flex; gap: 10px; font-size: 13px; color: var(--text2); line-height: 1.6; }
.item-dot { color: var(--accent); flex-shrink: 0; font-weight: 700; }

/* Empty state */
.empty-section {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px 120px;
}
.empty-inner {
  text-align: center;
  padding: 80px 40px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
}
.empty-icon { font-size: 48px; margin-bottom: 20px; }
.empty-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(12px, 2vw, 16px);
  color: var(--text);
  line-height: 1.6;
  margin-bottom: 12px;
}
.empty-desc {
  font-size: 13px;
  color: var(--text2);
  line-height: 1.8;
}
</style>
