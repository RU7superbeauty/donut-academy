---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const featured = articles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---
<BaseLayout
  title="Donut Academy — AI-Native Crypto Trading"
  description="Learn D0. Build autonomous trading agents. Master the architecture of AI-native crypto trading infrastructure."
>

<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section class="hero-section">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span data-i18n="home.badge">D0 Agent · Private Beta · Telegram · HyperLiquid + Polymarket</span>
    </div>

    <h1 class="hero-headline" data-i18n="home.headline">
      Your Personal<br>Trading Agent.
    </h1>
    <p class="hero-sub" data-i18n="home.sub">
      D0 是你的个人交易 Agent —— 通过 Telegram 对话，将交易意图转化为<br class="break-desktop">
      安全、快速、可审计的链上执行。169+ 工具，一句话搞定。
    </p>

    <div class="hero-actions">
      <a href="/learn/quickstart/" class="btn-primary" data-i18n="home.ctaQuickstart">QUICK START →</a>
      <a href="/learn/" class="btn-ghost" data-i18n="home.ctaCurriculum">BROWSE CURRICULUM</a>
    </div>

    <!-- Terminal Demo — Telegram Conversation Style -->
    <div class="terminal">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="terminal-title">D0 Agent — Telegram</span>
      </div>
      <div class="terminal-body" id="terminalBody">
        <div class="t-line"><span class="t-prompt">You</span> <span class="t-cmd">What's the price of ETH?</span></div>
        <div class="t-line t-out">ETH/USDC  <span class="t-hl">$3,247.50</span>  +2.3% 24h  Vol $18.2B</div>
        <div class="t-line t-gap"></div>
        <div class="t-line"><span class="t-prompt">You</span> <span class="t-cmd">Give me a TA on BTC</span></div>
        <div class="t-line t-out">RSI(14) <span class="t-gold">34.2</span> · MACD <span class="t-green">bullish cross</span> · Signal: <span class="t-hl">LONG</span></div>
        <div class="t-line t-gap"></div>
        <div class="t-line"><span class="t-prompt">You</span> <span class="t-cmd">Buy 0.1 ETH on HyperLiquid, limit 3200</span></div>
        <div class="t-line t-out">🔒 Confirm: <span class="t-hl">BUY 0.1 ETH</span> @ limit $3,200 on HyperLiquid</div>
        <div class="t-line"><span class="t-prompt">You</span> <span class="t-cmd">Yes</span></div>
        <div class="t-line t-out t-success">✓ Order placed · Filled @ $3,200.40 · Position open</div>
        <div class="t-line t-gap"></div>
        <div class="t-line t-cursor"><span class="t-prompt">You</span> <span class="cursor-blink">▊</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     STATS BAR
══════════════════════════════════════════ -->
<section class="stats-bar">
  <div class="stats-inner">
    <div class="stat">
      <span class="stat-num">169+</span>
      <span class="stat-label" data-i18n="home.statsTools">Tools Available</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">9</span>
      <span class="stat-label" data-i18n="home.statsIntegrations">Integration Layers</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">DSEA</span>
      <span class="stat-label" data-i18n="home.statsDSEA">Agentic Engine</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">30min</span>
      <span class="stat-label" data-i18n="home.statsTrade">To First Trade</span>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     THREE PATHS
══════════════════════════════════════════ -->
<section class="paths-section">
  <div class="section-label" data-i18n="home.pathsLabel">WHERE TO START</div>
  <h2 class="section-heading" data-i18n="home.pathsHeading">Choose Your Path</h2>

  <div class="paths-grid">
    <a href="/learn/quickstart/" class="path-card">
      <div class="path-icon">🚀</div>
      <div class="path-tier" data-i18n="home.pathBeginner">BEGINNER</div>
      <h3 class="path-title" data-i18n="home.pathQuickStart">Quick Start</h3>
      <p class="path-desc" data-i18n="home.pathQuickStartDesc">从安装 D0 到执行第一笔交易，30 分钟上手完整流程。无需任何量化背景。</p>
      <div class="path-meta">
        <span data-i18n="home.pathSteps">4 steps</span>
        <span data-i18n="home.pathTime30">30 min</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a href="/playbook/" class="path-card path-card-gold">
      <div class="path-icon">⚡</div>
      <div class="path-tier" data-i18n="home.pathTrader">TRADER</div>
      <h3 class="path-title" data-i18n="home.pathPlaybook">Playbook</h3>
      <p class="path-desc" data-i18n="home.pathPlaybookDesc">可直接执行的交易 workflow — 资金费率套利、鲸鱼监控、MM 行为识别。</p>
      <div class="path-meta">
        <span data-i18n="home.pathWorkflows">3 workflows</span>
        <span data-i18n="home.pathTimeEach">20-45 min each</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a href="/research/" class="path-card path-card-purple">
      <div class="path-icon">🔬</div>
      <div class="path-tier" data-i18n="home.pathBuilder">BUILDER</div>
      <h3 class="path-title" data-i18n="home.pathResearch">Research</h3>
      <p class="path-desc" data-i18n="home.pathResearchDesc">深入 Agent 交易基础设施的底层问题 — 意图解析、风控失效、博弈均衡。</p>
      <div class="path-meta">
        <span data-i18n="home.pathPapers">5 papers</span>
        <span data-i18n="home.pathTimeResearch">15-30 min each</span>
        <span class="path-arrow">→</span>
      </div>
    </a>
  </div>
</section>

<!-- ══════════════════════════════════════════
     QUICK START STRIP
══════════════════════════════════════════ -->
<section class="quickstart-strip">
  <div class="qs-inner">
    <div class="qs-text">
      <div class="section-label" data-i18n="home.qsLabel">GET STARTED IN 3 LINES</div>
      <h2 class="qs-heading" data-i18n="home.qsHeading">One auth. Full access.</h2>
      <p class="qs-desc" data-i18n="home.qsDesc">D0 使用 Turnkey 云端密钥托管。一次登录，所有读写操作全部开箱即用。</p>
      <a href="/learn/quickstart/" class="btn-primary" style="margin-top:20px" data-i18n="home.qsCta">FULL QUICKSTART →</a>
    </div>
    <div class="qs-code">
      <div class="code-block">
        <div class="code-line">
          <span class="code-comment"># 1. Install</span>
        </div>
        <div class="code-line copyable">
          <code>npm install -g @donutlabs-ai/d0-cli</code>
          <button class="copy-btn" data-copy="npm install -g @donutlabs-ai/d0-cli">COPY</button>
        </div>
        <div class="code-line">
          <span class="code-comment"># 2. Authenticate</span>
        </div>
        <div class="code-line copyable">
          <code>d0 login</code>
          <button class="copy-btn" data-copy="d0 login">COPY</button>
        </div>
        <div class="code-line">
          <span class="code-comment"># 3. Your first query</span>
        </div>
        <div class="code-line copyable">
          <code>d0 price ETH</code>
          <button class="copy-btn" data-copy="d0 price ETH">COPY</button>
        </div>
        <div class="code-output">
          <span class="out-text">ETH/USDC  <strong>$3,247.50</strong>  +2.3% 24h</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     DSEA ENGINE
══════════════════════════════════════════ -->
<section class="dsea-section">
  <div class="dsea-inner">
    <div class="dsea-text">
      <div class="section-label" data-i18n="home.dseaLabel">THE AGENTIC LOOP</div>
      <h2 class="section-heading" data-i18n="home.dseaHeading">DSEA Engine</h2>
      <p class="dsea-desc" data-i18n="home.dseaDesc">
        D0 的核心是 DSEA 循环 —— Discovery, Strategy, Execution, Attribution。
        将碎片化的手动操作替换为结构化、可验证的 Agent 执行流程。
      </p>
    </div>
    <div class="dsea-grid">
      {[
        { letter: 'D', title: 'Discovery', desc: '感知层 — 持续扫描鲸鱼动向、流动性变化、社交叙事、宏观信号', i18nDesc: 'home.dseaD' },
        { letter: 'S', title: 'Strategy', desc: '边界层 — 你定义规则：资产、敞口、风控，Agent 在你的法则内执行', i18nDesc: 'home.dseaS' },
        { letter: 'E', title: 'Execution', desc: '执行层 — 跨集成场所路由最优成交，最小化滑点和失败交易', i18nDesc: 'home.dseaE' },
        { letter: 'A', title: 'Attribution', desc: '归因层 — 做了什么、为什么、花了多少、结果如何，每一步可审计', i18nDesc: 'home.dseaA' },
      ].map(step => (
        <div class="dsea-card">
          <div class="dsea-letter">{step.letter}</div>
          <div>
            <span class="dsea-title">{step.title}</span>
            <span class="dsea-card-desc" data-i18n={step.i18nDesc}>{step.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     KEY INTEGRATIONS
══════════════════════════════════════════ -->
<section class="integrations-section">
  <div class="section-label" data-i18n="home.intLabel">FULL-SPECTRUM STACK</div>
  <h2 class="section-heading" data-i18n="home.intHeading">Key Integrations</h2>
  <p class="int-desc" data-i18n="home.intDesc">
    169+ 工具覆盖完整交易栈 —— 从行情到执行、从链上到宏观。
  </p>

  <div class="int-grid">
    {[
      { icon: '📈', layer: 'Perpetuals DEX', name: 'HyperLiquid', desc: '229+ 资产，最高 50x 杠杆，全订单生命周期管理' },
      { icon: '🎯', layer: 'Prediction Markets', name: 'Polymarket', desc: 'Polygon 上的预测市场，实时赔率与流动性' },
      { icon: '💹', layer: 'Price & Market Data', name: 'CoinGecko · Binance · DexScreener', desc: '实时现货/合约定价、24h 成交量、深度数据' },
      { icon: '📊', layer: 'Technical Analysis', name: 'Built-in TA Engine', desc: 'RSI-14, MACD, MA(20/60), 布林带, 支撑/阻力' },
      { icon: '🔥', layer: 'Derivatives Intel', name: 'Binance Futures · CoinAnk', desc: '持仓量、资金费率、多空比、大户持仓' },
      { icon: '🐋', layer: 'Whale Tracking', name: 'Whale Alert · Arkham', desc: '大额转账警报、钱包标签、资金流向分析' },
      { icon: '🌍', layer: 'Macro & Sentiment', name: 'Yahoo Finance · Alternative.me', desc: 'VIX, DXY, US10Y, 恐惧贪婪指数, 宏观新闻' },
      { icon: '🏗️', layer: 'Fundamentals', name: 'RootData · DeFiLlama', desc: '项目融资、团队背景、TVL 追踪' },
      { icon: '🔐', layer: 'Key Custody', name: 'Turnkey HSM', desc: '硬件安全模块，私钥永不离开安全飞地' },
    ].map(item => (
      <div class="int-card">
        <div class="int-icon">{item.icon}</div>
        <div class="int-layer">{item.layer}</div>
        <div class="int-name">{item.name}</div>
        <div class="int-card-desc">{item.desc}</div>
      </div>
    ))}
  </div>
</section>

