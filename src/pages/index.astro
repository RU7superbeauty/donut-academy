---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const featured = articles
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);
---
<BaseLayout
  title="Donut Academy — AI-Native Crypto Trading"
  description="Learn D0. Build autonomous trading agents. Master the architecture of AI-native crypto trading infrastructure."
>

<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section class="hero-section">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      <span data-i18n="home.badge">D0 CLI · Private Beta · Hyperliquid + Polymarket</span>
    </div>

    <h1 class="hero-headline" data-i18n="home.headline">
      The AI Agent<br>Trading Infrastructure.
    </h1>
    <p class="hero-sub" data-i18n="home.sub">
      D0 是专为 AI Agent 设计的加密交易 CLI。不是给人点击按钮的 GUI，<br class="break-desktop">
      而是从第一行代码开始就为 Agent 而生的执行层。
    </p>

    <div class="hero-actions">
      <a href="/learn/quickstart/" class="btn-primary" data-i18n="home.ctaQuickstart">QUICK START →</a>
      <a href="/learn/" class="btn-ghost" data-i18n="home.ctaCurriculum">BROWSE CURRICULUM</a>
    </div>

    <!-- Terminal Demo -->
    <div class="terminal">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="terminal-title">d0 — zsh</span>
      </div>
      <div class="terminal-body" id="terminalBody">
        <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">d0 login</span></div>
        <div class="t-line t-out">✓ Authenticated as @you · Turnkey wallet ready</div>
        <div class="t-line t-gap"></div>
        <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">d0 price ETH</span></div>
        <div class="t-line t-out">ETH/USDC  <span class="t-hl">$3,247.50</span>  +2.3% 24h  Vol $18.2B</div>
        <div class="t-line t-gap"></div>
        <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">d0 ta BTC</span></div>
        <div class="t-line t-out">RSI(14) <span class="t-gold">34.2</span> · MACD <span class="t-green">bullish cross</span> · Signal: <span class="t-hl">LONG</span></div>
        <div class="t-line t-gap"></div>
        <div class="t-line"><span class="t-prompt">$</span> <span class="t-cmd">d0 hl:limit buy ETH 0.1 3200</span></div>
        <div class="t-line t-out t-success">✓ Order placed · Filled @ $3,200.40 · Position open</div>
        <div class="t-line t-gap"></div>
        <div class="t-line t-cursor"><span class="t-prompt">$</span> <span class="cursor-blink">▊</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     STATS BAR
══════════════════════════════════════════ -->
<section class="stats-bar">
  <div class="stats-inner">
    <div class="stat">
      <span class="stat-num">169+</span>
      <span class="stat-label" data-i18n="home.statsTools">Tools Available</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">3</span>
      <span class="stat-label" data-i18n="home.statsExchanges">Exchanges Integrated</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">5</span>
      <span class="stat-label" data-i18n="home.statsResearch">Active Research Topics</span>
    </div>
    <div class="stat-divider"></div>
    <div class="stat">
      <span class="stat-num">30min</span>
      <span class="stat-label" data-i18n="home.statsTrade">To First Trade</span>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     THREE PATHS
══════════════════════════════════════════ -->
<section class="paths-section">
  <div class="section-label" data-i18n="home.pathsLabel">WHERE TO START</div>
  <h2 class="section-heading" data-i18n="home.pathsHeading">Choose Your Path</h2>

  <div class="paths-grid">
    <a href="/learn/quickstart/" class="path-card">
      <div class="path-icon">🚀</div>
      <div class="path-tier" data-i18n="home.pathBeginner">BEGINNER</div>
      <h3 class="path-title" data-i18n="home.pathQuickStart">Quick Start</h3>
      <p class="path-desc" data-i18n="home.pathQuickStartDesc">从安装 D0 到执行第一笔交易，30 分钟上手完整流程。无需任何量化背景。</p>
      <div class="path-meta">
        <span data-i18n="home.pathSteps">4 steps</span>
        <span data-i18n="home.pathTime30">30 min</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a href="/playbook/" class="path-card path-card-gold">
      <div class="path-icon">⚡</div>
      <div class="path-tier" data-i18n="home.pathTrader">TRADER</div>
      <h3 class="path-title" data-i18n="home.pathPlaybook">Playbook</h3>
      <p class="path-desc" data-i18n="home.pathPlaybookDesc">可直接执行的交易 workflow — 资金费率套利、鲸鱼监控、MM 行为识别。</p>
      <div class="path-meta">
        <span data-i18n="home.pathWorkflows">3 workflows</span>
        <span data-i18n="home.pathTimeEach">20-45 min each</span>
        <span class="path-arrow">→</span>
      </div>
    </a>

    <a href="/research/" class="path-card path-card-purple">
      <div class="path-icon">🔬</div>
      <div class="path-tier" data-i18n="home.pathBuilder">BUILDER</div>
      <h3 class="path-title" data-i18n="home.pathResearch">Research</h3>
      <p class="path-desc" data-i18n="home.pathResearchDesc">深入 Agent 交易基础设施的底层问题 — 意图解析、风控失效、博弈均衡。</p>
      <div class="path-meta">
        <span data-i18n="home.pathPapers">5 papers</span>
        <span data-i18n="home.pathTimeResearch">15-30 min each</span>
        <span class="path-arrow">→</span>
      </div>
    </a>
  </div>
</section>

<!-- ══════════════════════════════════════════
     QUICK START STRIP
══════════════════════════════════════════ -->
<section class="quickstart-strip">
  <div class="qs-inner">
    <div class="qs-text">
      <div class="section-label" data-i18n="home.qsLabel">GET STARTED IN 3 LINES</div>
      <h2 class="qs-heading" data-i18n="home.qsHeading">One auth. Full access.</h2>
      <p class="qs-desc" data-i18n="home.qsDesc">D0 使用 Turnkey 云端密钥托管。一次登录，所有读写操作全部开箱即用。</p>
      <a href="/learn/quickstart/" class="btn-primary" style="margin-top:20px" data-i18n="home.qsCta">FULL QUICKSTART →</a>
    </div>
    <div class="qs-code">
      <div class="code-block">
        <div class="code-line">
          <span class="code-comment"># 1. Install</span>
        </div>
        <div class="code-line copyable">
          <code>npm install -g @donutlabs-ai/d0-cli</code>
          <button class="copy-btn" data-copy="npm install -g @donutlabs-ai/d0-cli">COPY</button>
        </div>
        <div class="code-line">
          <span class="code-comment"># 2. Authenticate</span>
        </div>
        <div class="code-line copyable">
          <code>d0 login</code>
          <button class="copy-btn" data-copy="d0 login">COPY</button>
        </div>
        <div class="code-line">
          <span class="code-comment"># 3. Your first query</span>
        </div>
        <div class="code-line copyable">
          <code>d0 price ETH</code>
          <button class="copy-btn" data-copy="d0 price ETH">COPY</button>
        </div>
        <div class="code-output">
          <span class="out-text">ETH/USDC  <strong>$3,247.50</strong>  +2.3% 24h</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     FEATURED ARTICLES
══════════════════════════════════════════ -->
<section class="articles-section">
  <div class="articles-header">
    <div>
      <div class="section-label" data-i18n="home.articlesLabel">LATEST FROM DONUT RESEARCH</div>
      <h2 class="section-heading" data-i18n="home.articlesHeading">Featured Articles</h2>
    </div>
    <a href="/research/" class="link-all" data-i18n="home.articlesViewAll">View all →</a>
  </div>

  <div class="articles-grid">
    {featured.map(article => (
      <a href={`/articles/${article.slug}/`} class="article-card">
        <div class="article-cat">{article.data.category}</div>
        <h3 class="article-title">{article.data.title}</h3>
        <p class="article-desc">{article.data.description?.slice(0, 100)}…</p>
        <div class="article-meta">
          <span>{article.data.date}</span>
          <span class="article-read" data-i18n="home.articlesReadTime">5 min →</span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════════
     D0 DESIGN PRINCIPLES TEASER
══════════════════════════════════════════ -->
<section class="principles-section">
  <div class="principles-inner">
    <div class="principles-text">
      <div class="section-label" data-i18n="home.principlesLabel">D0 METHODOLOGY</div>
      <h2 class="section-heading" data-i18n="home.principlesHeading">5 Principles.<br>One Architecture.</h2>
      <p class="principles-desc" data-i18n="home.principlesDesc">
        CLI-as-API. Login-Once. Turnkey Security. Exchange Abstraction. Composable Skills.<br>
        每一条原则都指向同一个目标：让 AI Agent 成为交易的一等公民。
      </p>
      <a href="/articles/d0-design-principles/" class="btn-ghost" style="margin-top:20px" data-i18n="home.principlesCta">
        READ THE PRINCIPLES →
      </a>
    </div>
    <div class="principles-list">
      {[
        { num: '01', title: 'CLI-as-API', sub: '命令行即接口', i18nSub: 'home.p01sub' },
        { num: '02', title: 'Login-Once', sub: '一次认证全覆盖', i18nSub: 'home.p02sub' },
        { num: '03', title: 'Turnkey Secured', sub: '云端密钥托管', i18nSub: 'home.p03sub' },
        { num: '04', title: 'Exchange Abstraction', sub: '统一多交易所语义', i18nSub: 'home.p04sub' },
        { num: '05', title: 'Composable Skills', sub: '可组合技能系统', i18nSub: 'home.p05sub' },
      ].map(p => (
        <div class="principle-item">
          <span class="p-num">{p.num}</span>
          <div>
            <span class="p-title">{p.title}</span>
            <span class="p-sub" data-i18n={p.i18nSub}>{p.sub}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════
     QUOTE / THESIS
══════════════════════════════════════════ -->
<section class="thesis-section">
  <div class="thesis-inner">
    <blockquote class="thesis-quote" data-i18n="home.thesis">
      "链上交易的主体将从人类转移到 AI Agent。<br>
      谁拥有 Agent 的执行层，谁就拥有链上流量的入口。"
    </blockquote>
    <cite class="thesis-cite" data-i18n="home.thesisCite">— D0 THESIS / 2026</cite>
    <a href="/articles/agent-economy-thesis/" class="btn-ghost" style="margin-top:28px" data-i18n="home.thesisCta">
      READ THE FULL THESIS →
    </a>
  </div>
</section>

</BaseLayout>

<script>
// Copy button
document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const text = (btn as HTMLButtonElement).dataset.copy || '';
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = 'COPIED!';
      setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
    });
  });
});

// Terminal typewriter effect (subtle)
const cursor = document.querySelector('.cursor-blink') as HTMLElement;
if (cursor) {
  setInterval(() => cursor.style.opacity = cursor.style.opacity === '0' ? '1' : '0', 530);
}
</script>

<style>
/* ── Layout ── */
.hero-section, .stats-bar, .paths-section,
.quickstart-strip, .articles-section,
.principles-section, .thesis-section {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px;
}

/* ── Hero ── */
.hero-section { padding-top: 72px; padding-bottom: 0; }
.hero-inner { text-align: center; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--text2);
  border: 1px solid var(--border2);
  border-radius: 100px;
  padding: 5px 14px;
  margin-bottom: 28px;
}
.badge-dot {
  width: 6px; height: 6px;
  background: var(--green);
  border-radius: 50%;
  box-shadow: 0 0 6px var(--green);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.hero-headline {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(20px, 3.5vw, 36px);
  line-height: 1.6;
  letter-spacing: 1px;
  color: var(--text);
  margin-bottom: 20px;
}
.hero-headline strong { color: var(--accent); }

.hero-sub {
  font-size: 15px;
  color: var(--text2);
  line-height: 1.8;
  max-width: 560px;
  margin: 0 auto 32px;
}
.break-desktop { display: none; }
@media (min-width: 600px) { .break-desktop { display: block; } }

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 48px;
  flex-wrap: wrap;
}

/* Buttons */
.btn-primary {
  display: inline-block;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  color: #131320;
  background: var(--accent);
  padding: 12px 24px;
  border-radius: 4px;
  text-decoration: none;
  transition: background 0.15s, transform 0.1s;
}
.btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }

.btn-ghost {
  display: inline-block;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.5px;
  color: var(--accent);
  background: transparent;
  border: 1px solid var(--border2);
  padding: 12px 24px;
  border-radius: 4px;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.btn-ghost:hover { border-color: var(--accent); color: var(--accent2); }

/* Terminal */
.terminal {
  max-width: 640px;
  margin: 0 auto 80px;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid var(--border2);
  box-shadow: 0 24px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(172,170,255,0.1);
  text-align: left;
}
.terminal-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  background: #1e1e30;
  padding: 10px 16px;
  border-bottom: 1px solid var(--border);
}
.dot { width: 12px; height: 12px; border-radius: 50%; }
.dot.red { background: #ff5f57; }
.dot.yellow { background: #febc2e; }
.dot.green { background: #28c840; }
.terminal-title {
  flex: 1;
  text-align: center;
  font-size: 11px;
  color: var(--text2);
  font-family: 'Space Mono', monospace;
  margin-left: -46px;
}
.terminal-body {
  background: #0d0d1a;
  padding: 20px 24px;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  line-height: 1.6;
}
.t-line { display: flex; align-items: center; gap: 10px; min-height: 20px; }
.t-gap { height: 8px; }
.t-prompt { color: var(--accent); font-weight: 700; }
.t-cmd { color: var(--text); }
.t-out { color: var(--text2); padding-left: 20px; }
.t-hl { color: var(--accent); font-weight: 700; }
.t-gold { color: var(--gold); }
.t-green { color: #4ade80; }
.t-success { color: #4ade80; padding-left: 20px; }
.t-cursor { padding-top: 4px; }
.cursor-blink { color: var(--accent); transition: opacity 0.1s; }

/* ── Stats Bar ── */
.stats-bar {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  margin: 0 auto;
}
.stats-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 28px 0;
}
.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 0 40px;
}
.stat-num {
  font-family: 'Press Start 2P', monospace;
  font-size: 18px;
  color: var(--accent);
}
.stat-label {
  font-size: 11px;
  color: var(--text2);
  white-space: nowrap;
}
.stat-divider {
  width: 1px;
  height: 36px;
  background: var(--border);
}
@media (max-width: 600px) {
  .stats-inner { flex-wrap: wrap; gap: 24px; }
  .stat-divider { display: none; }
  .stat { padding: 0 20px; }
}

/* ── Section Labels ── */
.section-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 8px;
}
.section-heading {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(14px, 2vw, 20px);
  line-height: 1.6;
  color: var(--text);
  margin-bottom: 32px;
}

/* ── Three Paths ── */
.paths-section { padding-top: 80px; padding-bottom: 0; }
.paths-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.path-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 28px 24px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  text-decoration: none;
  transition: border-color 0.15s, transform 0.15s;
}
.path-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.path-card-gold:hover { border-color: var(--gold); }
.path-card-purple:hover { border-color: #9f7aea; }
.path-icon { font-size: 28px; }
.path-tier {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--accent);
}
.path-card-gold .path-tier { color: var(--gold); }
.path-card-purple .path-tier { color: #9f7aea; }
.path-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 13px;
  color: var(--text);
  line-height: 1.5;
}
.path-desc { font-size: 13px; color: var(--text2); line-height: 1.7; flex: 1; }
.path-meta {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  border-top: 1px solid var(--border);
  padding-top: 12px;
  margin-top: 4px;
}
.path-arrow { margin-left: auto; color: var(--accent); font-size: 14px; }

@media (max-width: 720px) {
  .paths-grid { grid-template-columns: 1fr; }
}

/* ── Quick Start Strip ── */
.quickstart-strip {
  padding-top: 80px;
  padding-bottom: 0;
}
.qs-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 48px;
}
.qs-heading {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(14px, 2vw, 20px);
  line-height: 1.6;
  color: var(--text);
  margin-bottom: 12px;
}
.qs-desc { font-size: 13px; color: var(--text2); line-height: 1.8; }

.code-block {
  background: #0d0d1a;
  border: 1px solid var(--border2);
  border-radius: 8px;
  padding: 20px 24px;
  font-family: 'Space Mono', monospace;
  font-size: 12px;
}
.code-comment { color: var(--muted); }
.code-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 24px;
  gap: 8px;
}
.code-line code { color: var(--text); flex: 1; }
.copyable { margin-bottom: 8px; }
.copy-btn {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  color: var(--accent);
  background: transparent;
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 3px 7px;
  cursor: pointer;
  transition: all 0.15s;
  flex-shrink: 0;
}
.copy-btn:hover { background: rgba(172,170,255,0.1); }
.code-output {
  margin-top: 8px;
  padding: 8px 12px;
  background: rgba(172,170,255,0.05);
  border-left: 2px solid var(--accent);
  border-radius: 0 4px 4px 0;
}
.out-text { font-size: 11px; color: var(--text2); }
.out-text strong { color: var(--accent); }

@media (max-width: 720px) {
  .qs-inner { grid-template-columns: 1fr; padding: 28px 20px; }
}

/* ── Articles Grid ── */
.articles-section { padding-top: 80px; }
.articles-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24px;
}
.link-all {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--accent);
  text-decoration: none;
}
.link-all:hover { color: var(--accent2); }
.articles-grid {
  display: grid;
