<!-- ══════════════════════════════════════════
     SECURITY
══════════════════════════════════════════ -->
<section class="security-section">
  <div class="section-label" data-i18n="home.secLabel">DEFENSE IN DEPTH</div>
  <h2 class="section-heading" data-i18n="home.secHeading">Security Architecture</h2>

  <div class="security-grid">
    <div class="sec-card sec-card-main">
      <div class="sec-icon">🔐</div>
      <h3 class="sec-title" data-i18n="home.secTurnkeyTitle">Turnkey HSM Key Custody</h3>
      <p class="sec-desc" data-i18n="home.secTurnkeyDesc">
        私钥在硬件安全模块 (HSM) 内生成和存储，永不暴露给应用层。
        所有签名请求经过 Turnkey API 验证后在安全飞地内完成。
      </p>
    </div>
    {[
      { icon: '👤', title: 'Human-in-the-Loop', desc: '所有交易需明确用户确认，无静默执行', i18nTitle: 'home.secHitlTitle', i18nDesc: 'home.secHitlDesc' },
      { icon: '🔍', title: 'Intent Verification', desc: 'AI 解析的意图以结构化格式回显确认', i18nTitle: 'home.secIntentTitle', i18nDesc: 'home.secIntentDesc' },
      { icon: '📏', title: 'Position Limits', desc: '可配置的最大仓位和杠杆上限，防止过度敞口', i18nTitle: 'home.secLimitTitle', i18nDesc: 'home.secLimitDesc' },
      { icon: '⚡', title: 'Slippage Protection', desc: '市价单包含滑点容忍度，超限自动拒绝', i18nTitle: 'home.secSlipTitle', i18nDesc: 'home.secSlipDesc' },
      { icon: '🔒', title: 'Session Isolation', desc: '用户间完全隔离，无跨会话数据泄露', i18nTitle: 'home.secIsoTitle', i18nDesc: 'home.secIsoDesc' },
    ].map(item => (
      <div class="sec-card">
        <div class="sec-icon">{item.icon}</div>
        <h3 class="sec-title" data-i18n={item.i18nTitle}>{item.title}</h3>
        <p class="sec-desc" data-i18n={item.i18nDesc}>{item.desc}</p>
      </div>
    ))}
  </div>
</section>

