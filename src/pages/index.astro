══════════════════════════════════════════ -->
<section class="articles-section">
  <div class="articles-header">
    <div>
      <div class="section-label" data-i18n="home.articlesLabel">LATEST FROM DONUT RESEARCH</div>
      <h2 class="section-heading" data-i18n="home.articlesHeading">Featured Articles</h2>
    </div>
    <a href="/research/" class="link-all" data-i18n="home.articlesViewAll">View all →</a>
  </div>

  <div class="articles-grid">
    {featured.map(article => (
      <a href={`/articles/${article.slug}/`} class="article-card">
        <div class="article-cat">{article.data.category}</div>
        <h3 class="article-title">{article.data.title}</h3>
        <p class="article-desc">{article.data.description?.slice(0, 100)}…</p>
        <div class="article-meta">
          <span>{article.data.date}</span>
          <span class="article-read" data-i18n="home.articlesReadTime">5 min →</span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══════════════════════════════════════════
     D0 DESIGN PRINCIPLES TEASER
══════════════════════════════════════════ -->
<section class="principles-section">
  <div class="principles-inner">
    <div class="principles-text">
      <div class="section-label" data-i18n="home.principlesLabel">D0 METHODOLOGY</div>
      <h2 class="section-heading" data-i18n="home.principlesHeading">5 Principles.<br>One Architecture.</h2>
      <p class="principles-desc" data-i18n="home.principlesDesc">
        Conversational Interface. Login-Once. Turnkey Secured. Exchange Abstraction. Composable Skills.<br>
        每一条原则都指向同一个目标：让 AI Agent 成为交易的一等公民。
      </p>
      <a href="/articles/d0-design-principles/" class="btn-ghost" style="margin-top:20px" data-i18n="home.principlesCta">
        READ THE PRINCIPLES →
      </a>
    </div>
    <div class="principles-list">
      {[
        { num: '01', title: 'Conversational Interface', sub: '自然语言即接口', i18nSub: 'home.p01sub' },
        { num: '02', title: 'Login-Once', sub: '一次认证全覆盖', i18nSub: 'home.p02sub' },
        { num: '03', title: 'Turnkey Secured', sub: '云端密钥托管', i18nSub: 'home.p03sub' },
        { num: '04', title: 'Exchange Abstraction', sub: '统一多交易所语义', i18nSub: 'home.p04sub' },
        { num: '05', title: 'Composable Skills', sub: '可组合技能系统', i18nSub: 'home.p05sub' },
      ].map(p => (
        <div class="principle-item">
          <span class="p-num">{p.num}</span>
          <div>
            <span class="p-title">{p.title}</span>
            <span class="p-sub" data-i18n={p.i18nSub}>{p.sub}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

