---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { languages, type Lang, useTranslations } from '../../../i18n';

export async function getStaticPaths() {
  const entries = await getCollection('playbook');
  const paths = [];
  for (const langCode of Object.keys(languages)) {
    for (const entry of entries) {
      paths.push({
        params: { lang: langCode, slug: entry.id },
        props: { entry, lang: langCode },
      });
    }
  }
  return paths;
}

const { entry, lang } = Astro.props as { entry: any; lang: Lang };
const t = useTranslations(lang);
const { Content, headings } = await render(entry);
const { title, subtitle, date, difficulty, time, category, tags, description, commands, prerequisites } = entry.data;

const wordCount = (entry.body || '').split(/\s+/).length;
const readingTime = Math.max(5, Math.ceil(wordCount / 200));
---
<BaseLayout title={title} description={description} lang={lang}>

<nav class="breadcrumb">
  <a href={`/${lang}/playbook/`}>{t('playbook.label')}</a>
  <span>›</span>
  <span class="bc-cat">{category}</span>
</nav>

<header class="pb-header">
  <div class="pb-meta-top">
    <span class="cat-badge">{category}</span>
    <span class="meta-sep">·</span>
    <span class="meta-item">{difficulty}</span>
    <span class="meta-sep">·</span>
    <span class="meta-item">⏱ {time}</span>
    <span class="meta-sep">·</span>
    <span class="meta-item">📅 {date}</span>
    <span class="meta-sep">·</span>
    <span class="meta-item">{readingTime} min</span>
  </div>
  <h1 class="pb-title">{title}</h1>
  <p class="pb-subtitle">{subtitle}</p>
  <div class="pb-tags">
    {tags.map((tag: string) => <span class="tag-pill">{tag}</span>)}
  </div>
</header>

<div class="pb-layout">
  <aside class="pb-sidebar">
    {prerequisites && prerequisites.length > 0 && (
      <div class="sidebar-block">
        <div class="sidebar-title">{lang === 'zh' ? '前置条件' : 'PREREQUISITES'}</div>
        <ul class="prereq-list">
          {prerequisites.map((p: string) => (
            <li class="prereq-item">
              <span class="prereq-dot">✓</span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {commands && commands.length > 0 && (
      <div class="sidebar-block">
        <div class="sidebar-title">{lang === 'zh' ? '关键命令' : 'D0 COMMANDS'}</div>
        <div class="cmd-list">
          {commands.map((cmd: string) => (
            <code class="cmd-pill">{cmd}</code>
          ))}
        </div>
      </div>
    )}

    {headings.length > 0 && (
      <div class="sidebar-block">
        <div class="sidebar-title">{lang === 'zh' ? '目录' : 'CONTENTS'}</div>
        <nav class="sidebar-toc">
          {headings.filter((h: any) => h.depth <= 3).map((h: any) => (
            <a class="toc-link" href={`#${h.slug}`} style={h.depth === 3 ? 'margin-left: 10px' : ''}>{h.text}</a>
          ))}
        </nav>
      </div>
    )}
  </aside>

  <article class="pb-article">
    <div class="article-body">
      <Content />
    </div>
  </article>
</div>

</BaseLayout>

<style>
/* Copy styling from existing playbook page */
.breadcrumb {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 72px 24px 0;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 10px;
}
.breadcrumb a { color: var(--text2); text-decoration: none; }
.breadcrumb a:hover { color: var(--accent); }
.bc-cat { color: var(--text); }

.pb-header {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 18px 24px 28px;
}
.pb-meta-top {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--text2);
}
.cat-badge {
  font-size: 10px;
  font-weight: 700;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 3px 8px;
}
.meta-sep { color: var(--muted); }
.pb-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(16px, 2.6vw, 26px);
  color: var(--text);
  margin: 14px 0 10px;
  line-height: 1.5;
}
.pb-subtitle { font-size: 14px; color: var(--text2); line-height: 1.8; max-width: 820px; }
.pb-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
.tag-pill {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--text2);
  border: 1px solid var(--border);
  padding: 3px 8px;
}

.pb-layout {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px 96px;
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: 24px;
}
.pb-sidebar { position: sticky; top: 86px; align-self: start; display: flex; flex-direction: column; gap: 12px; }
.sidebar-block { background: var(--surface); border: 1px solid var(--border); padding: 12px; }
.sidebar-title {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 10px;
}
.prereq-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.prereq-item { display: flex; gap: 8px; color: var(--text2); font-size: 12px; line-height: 1.4; }
.prereq-dot { color: var(--green); }
.cmd-list { display: flex; flex-wrap: wrap; gap: 6px; }
.cmd-pill {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--accent);
  background: rgba(172,170,255,0.08);
  border: 1px solid rgba(172,170,255,0.25);
  padding: 3px 6px;
}
.sidebar-toc { display: flex; flex-direction: column; gap: 6px; }
.toc-link { font-size: 11px; color: var(--text2); text-decoration: none; }
.toc-link:hover { color: var(--accent); }

.pb-article { min-width: 0; }

@media (max-width: 920px) {
  .pb-layout { grid-template-columns: 1fr; }
  .pb-sidebar { position: static; }
}
</style>
