---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { languages, type Lang, useTranslations } from '../../../i18n';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const updates = [
  { date: '2026-03-07', title: 'Academy Launch', desc: lang === 'zh' ? '15 篇深度文章上线，覆盖 AI 前沿、D0 方法论和 Donut Research 三大板块。' : '15 deep-dive articles published, covering AI Frontier, D0 Methodology, and Donut Research.', tag: 'CONTENT' },
  { date: '2026-03-07', title: 'i18n Support', desc: lang === 'zh' ? '多语言支持上线，目前支持英文和中文。' : 'Multi-language support launched. Currently supporting English and Chinese.', tag: 'FEATURE' },
  { date: '2026-03-06', title: 'Curriculum Structure', desc: lang === 'zh' ? '三层课程体系搭建完成：入门 → 进阶 → 前沿。' : 'Three-tier curriculum structure complete: Intro → Advanced → Frontier.', tag: 'CONTENT' },
];
---
<BaseLayout title={t('updates.title')} description={t('updates.desc')} lang={lang}>

<section class="page-hero">
  <div class="section-label">{t('updates.label')}</div>
  <h1 class="page-title">{t('updates.title')}</h1>
  <p class="page-desc">{t('updates.desc')}</p>
</section>

<section class="updates-list">
  {updates.map(u => (
    <div class="update-row">
      <div class="update-date">{u.date}</div>
      <div class="update-body">
        <span class="update-tag">{u.tag}</span>
        <h3 class="update-title">{u.title}</h3>
        <p class="update-desc">{u.desc}</p>
      </div>
    </div>
  ))}
</section>

</BaseLayout>
<style>
.page-hero { max-width: var(--max-w); margin: 0 auto; padding: 64px 24px 40px; }
.page-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(18px, 3vw, 28px);
  color: var(--text);
  margin: 8px 0 16px;
  line-height: 1.5;
}
.page-desc { font-size: 14px; color: var(--text2); line-height: 1.8; }

.section-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 8px;
}

.changelog-section {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px 80px;
  display: flex;
  flex-direction: column;
  gap: 0;
  border-left: 2px solid var(--border);
  margin-left: calc(24px + 80px);
  position: relative;
}

@media (max-width: 600px) {
  .changelog-section { margin-left: 24px; }
}

.entry {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 32px;
  padding: 32px 0 32px 32px;
  border-bottom: 1px solid var(--border);
  position: relative;
}
.entry::before {
  content: '';
  position: absolute;
  left: -7px;
  top: 38px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg);
}

@media (max-width: 600px) {
  .entry { grid-template-columns: 1fr; gap: 12px; }
}

.entry-meta { display: flex; flex-direction: column; gap: 6px; padding-top: 2px; }
.entry-type {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 3px 8px;
  border-radius: 3px;
  width: fit-content;
}
.type-major { color: var(--accent); background: rgba(172,170,255,0.12); }
.type-content { color: var(--gold); background: rgba(232,184,78,0.1); }
.type-fix { color: var(--green); background: rgba(6,151,66,0.1); }

.entry-version {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
}
.entry-date {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
}
.entry-title { font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 14px; }
.entry-items { display: flex; flex-direction: column; gap: 8px; list-style: none; }
.entry-item { display: flex; gap: 10px; font-size: 13px; color: var(--text2); line-height: 1.6; }
.item-dot { color: var(--accent); flex-shrink: 0; font-weight: 700; }
</style>
