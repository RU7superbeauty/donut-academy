---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { languages, type Lang, useTranslations } from '../../../i18n';

export async function getStaticPaths() {
  const entries = await getCollection('courses');
  const paths = [];
  for (const langCode of Object.keys(languages)) {
    for (const entry of entries) {
      paths.push({
        params: { lang: langCode, slug: entry.id },
        props: { entry, lang: langCode },
      });
    }
  }
  return paths;
}

const { entry, lang } = Astro.props as { entry: any; lang: Lang };
const t = useTranslations(lang);
const { Content, headings } = await render(entry);
const { title, subtitle, tier, order, time, tags, description, commands, status } = entry.data;

const tierLabel = { '1': t('learn.tier1'), '2': t('learn.tier2'), '3': t('learn.tier3') }[tier];
const tierColor = { '1': '#069742', '2': '#e8b84e', '3': '#ACAAFF' }[tier];

const allCourses = await getCollection('courses');
const sorted = allCourses.sort((a, b) => a.data.order - b.data.order);
const idx = sorted.findIndex(c => c.id === entry.id);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;
---
<BaseLayout title={title} description={description || subtitle} lang={lang}>

<section class="course-page">
  <a href={`/${lang}/learn/`} class="back-link">{t('quickstart.back')}</a>

  <div class="course-header">
    <div class="course-badge" style={`border-color:${tierColor};color:${tierColor}`}>{tierLabel}</div>
    <div class="course-num-big">{String(order).padStart(2, '0')}</div>
    <h1 class="course-h1">{title}</h1>
    <p class="course-sub">{subtitle}</p>
    <div class="course-info">
      <span>⏱ {time}</span>
      {commands && commands.map((cmd: string) => <code class="course-cmd">{cmd}</code>)}
    </div>
  </div>

  {headings.length > 0 && (
    <div class="toc">
      <div class="toc-title">{t('ui.toc')}</div>
      <ol>
        {headings.filter((h: any) => h.depth <= 3).map((h: any) => (
          <li style={h.depth === 3 ? 'margin-left:16px' : ''}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ol>
    </div>
  )}

  <div class="course-body">
    <Content />
  </div>

  <div class="course-nav">
    {prev ? <a href={`/${lang}/learn/${prev.id}/`}>← {prev.data.title}</a> : <span></span>}
    {next ? <a href={`/${lang}/learn/${next.id}/`}>{next.data.title} →</a> : <span></span>}
  </div>
</section>

</BaseLayout>
<style>
.breadcrumb {
  max-width: var(--max-w); margin: 0 auto; padding: 24px 24px 0;
  display: flex; align-items: center; gap: 8px;
  font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted);
}
.breadcrumb a { color: var(--accent); text-decoration: none; }

.course-header { max-width: var(--max-w); margin: 0 auto; padding: 28px 24px 36px; }
.course-meta-top { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
.tier-badge {
  font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700;
  letter-spacing: 0.8px; padding: 4px 10px; border-radius: 4px; border: 1px solid;
}
.meta-sep { color: var(--border2); }
.meta-item { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--text2); }
.course-title {
  font-family: 'Press Start 2P', monospace; font-size: clamp(13px, 2.2vw, 20px);
  color: var(--text); line-height: 1.6; margin-bottom: 12px;
}
.course-subtitle { font-size: 15px; color: var(--text2); line-height: 1.7; margin-bottom: 16px; }
.course-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.tag-pill { font-size: 10px; color: var(--muted); border: 1px solid var(--border); border-radius: 3px; padding: 3px 8px; }

.course-layout {
  max-width: var(--max-w); margin: 0 auto; padding: 0 24px;
  display: grid; grid-template-columns: 200px 1fr; gap: 40px; align-items: start;
}
.course-sidebar { position: sticky; top: 76px; display: flex; flex-direction: column; gap: 16px; }
.sidebar-block { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }
.sidebar-title { font-family: 'Space Mono', monospace; font-size: 9px; font-weight: 700; letter-spacing: 1.5px; color: var(--muted); margin-bottom: 10px; }
.cmd-list { display: flex; flex-direction: column; gap: 5px; }
.cmd-pill { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--accent); background: rgba(172,170,255,0.08); border: 1px solid var(--border); padding: 3px 7px; border-radius: 3px; word-break: break-all; }
.sidebar-link { display: block; font-size: 12px; color: var(--accent); text-decoration: none; margin-bottom: 5px; }
.sidebar-link:hover { color: var(--accent2); }

.course-body { min-width: 0; padding-bottom: 48px; }
.course-body :global(h2) { font-family: 'Press Start 2P', monospace; font-size: 13px; color: var(--text); margin: 36px 0 14px; line-height: 1.6; }
.course-body :global(h3) { font-size: 14px; font-weight: 700; color: var(--text); margin: 24px 0 10px; }
.course-body :global(p) { font-size: 14px; color: var(--text2); line-height: 1.85; margin-bottom: 14px; }
.course-body :global(ul), .course-body :global(ol) { margin: 10px 0 14px 20px; }
.course-body :global(li) { font-size: 14px; color: var(--text2); line-height: 1.8; margin-bottom: 5px; }
.course-body :global(code) { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--accent); background: rgba(172,170,255,0.1); padding: 2px 5px; border-radius: 3px; }
.course-body :global(pre) { background: #0d0d1a; border: 1px solid var(--border); border-radius: 8px; padding: 18px 20px; overflow-x: auto; margin: 14px 0; }
.course-body :global(pre code) { background: none; padding: 0; color: var(--text); font-size: 12px; line-height: 1.7; }
.course-body :global(blockquote) { border-left: 3px solid var(--accent); padding: 10px 16px; background: rgba(172,170,255,0.05); border-radius: 0 6px 6px 0; margin: 16px 0; }
.course-body :global(blockquote p) { color: var(--text2); font-style: italic; margin: 0; }
.course-body :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 13px; }
.course-body :global(th) { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.8px; color: var(--accent); padding: 9px 12px; border-bottom: 1px solid var(--border2); text-align: left; }
.course-body :global(td) { padding: 9px 12px; border-bottom: 1px solid var(--border); color: var(--text2); vertical-align: top; }
.course-body :global(strong) { color: var(--text); font-weight: 700; }
.course-body :global(a) { color: var(--accent); text-decoration: none; border-bottom: 1px solid rgba(172,170,255,0.3); }
.course-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 28px 0; }

.course-nav {
  max-width: var(--max-w); margin: 0 auto; padding: 32px 24px 80px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  border-top: 1px solid var(--border);
}
.nav-course { display: flex; flex-direction: column; gap: 6px; padding: 16px 20px; background: var(--card); border: 1px solid var(--border); border-radius: 8px; text-decoration: none; transition: border-color 0.15s; }
.nav-course:hover { border-color: var(--border2); }
.nav-dir { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; color: var(--accent); }
.nav-next .nav-dir { text-align: right; }
.nav-title { font-size: 12px; color: var(--text2); line-height: 1.4; }
.nav-next .nav-title { text-align: right; }

@media (max-width: 720px) {
  .course-layout { grid-template-columns: 1fr; }
  .course-sidebar { position: static; }
  .course-nav { grid-template-columns: 1fr; }
  .nav-next .nav-dir, .nav-next .nav-title { text-align: left; }
}
</style>
