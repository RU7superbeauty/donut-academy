---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCourses = await getCollection('courses');
const sorted = allCourses.sort((a, b) => a.data.order - b.data.order);

const tiers = [
  { tier: '1', label: 'TIER 1 — INTRO / 入门', color: 'green' },
  { tier: '2', label: 'TIER 2 — ADVANCED / 进阶', color: 'gold' },
  { tier: '3', label: 'TIER 3 — FRONTIER / 前沿', color: 'accent' },
];
---
<BaseLayout title="Learn D0" description="Structured curriculum from D0 Quick Start to autonomous trading pipelines.">

<section class="page-hero">
  <div class="section-label" data-i18n="learn.label">CURRICULUM</div>
  <h1 class="page-title" data-i18n="learn.title">Learn D0</h1>
  <p class="page-desc" data-i18n="learn.desc">从安装到构建自主交易 pipeline，三层 12 门课程，每一层都以 D0 为实战平台。</p>
</section>

<!-- Quick Start CTA -->
<section class="qs-cta-section">
  <a href="/learn/quickstart/" class="qs-cta-card">
    <div class="qs-badge" data-i18n="learn.startHere">START HERE</div>
    <h2 class="qs-title" data-i18n="learn.qsTitle">⚡ Quick Start — 30 Minutes to First Trade</h2>
    <p class="qs-desc" data-i18n="learn.qsDesc">安装 D0 → 登录 → 查询行情 → 执行第一笔交易。完整流程，30 分钟搞定。</p>
    <span class="qs-cta-btn" data-i18n="learn.qsCta">BEGIN →</span>
  </a>
</section>

<!-- Tiers with real course links -->
<section class="tiers-section">
  {tiers.map(t => {
    const tierCourses = sorted.filter(c => c.data.tier === t.tier);
    return (
      <div class={`tier-block tier-${t.color}`}>
        <div class="tier-header">
          <div class="tier-badge">{t.tier === '1' ? 'TIER 1' : t.tier === '2' ? 'TIER 2' : 'TIER 3'}</div>
          <h3 class="tier-label">{t.label}</h3>
          <span class="tier-count">{tierCourses.length} lessons</span>
        </div>
        <div class="tier-courses">
          {tierCourses.map(course => (
            <a href={`/learn/${course.id}/`} class={`course-card ${course.data.status === 'coming-soon' ? 'coming-soon' : ''}`}>
              <div class="course-num">{String(course.data.order).padStart(2, '0')}</div>
              <div class="course-body">
                <h4 class="course-title">{course.data.title}</h4>
                <p class="course-desc">{course.data.subtitle}</p>
                <div class="course-meta">
                  <span class="course-time">⏱ {course.data.time}</span>
                  {course.data.commands && course.data.commands.slice(0, 2).map((cmd: string) => (
                    <code class="course-d0">{cmd}</code>
                  ))}
                </div>
              </div>
              <div class={`course-status ${course.data.status}`}>
                {course.data.status === 'coming-soon' ? 'SOON' : '→'}
              </div>
            </a>
          ))}
        </div>
      </div>
    );
  })}
</section>

</BaseLayout>

<style>
.page-hero { max-width: var(--max-w); margin: 0 auto; padding: 64px 24px 32px; }
.page-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(18px, 3vw, 28px);
  color: var(--text); margin: 8px 0 16px; line-height: 1.5;
}
.page-desc { font-size: 14px; color: var(--text2); line-height: 1.8; max-width: 540px; }

.qs-cta-section { max-width: var(--max-w); margin: 0 auto; padding: 0 24px 40px; }
.qs-cta-card {
  display: flex; flex-direction: column; gap: 10px;
  padding: 36px 40px; background: var(--surface);
  border: 2px solid var(--accent); border-radius: 10px;
  text-decoration: none; transition: transform 0.15s; position: relative; overflow: hidden;
}
.qs-cta-card::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 0% 50%, rgba(172,170,255,0.08), transparent 60%);
  pointer-events: none;
}
.qs-cta-card:hover { transform: translateY(-2px); }
.qs-badge { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; color: #131320; background: var(--accent); padding: 3px 10px; border-radius: 3px; width: fit-content; }
.qs-title { font-size: 18px; font-weight: 700; color: var(--text); }
.qs-desc { font-size: 13px; color: var(--text2); line-height: 1.7; max-width: 560px; }
.qs-cta-btn { font-family: 'Space Mono', monospace; font-size: 12px; font-weight: 700; color: var(--accent); }

.section-label { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 2px; color: var(--accent); margin-bottom: 8px; }

.tiers-section { max-width: var(--max-w); margin: 0 auto; padding: 0 24px 80px; display: flex; flex-direction: column; gap: 24px; }
.tier-block { border-radius: 10px; overflow: hidden; border: 1px solid var(--border); }
.tier-header { display: flex; align-items: center; gap: 14px; padding: 16px 24px; background: var(--surface); border-bottom: 1px solid var(--border); }
.tier-badge { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 3px; }
.tier-green .tier-badge { color: var(--green); border: 1px solid var(--green); }
.tier-gold .tier-badge { color: var(--gold); border: 1px solid var(--gold); }
.tier-accent .tier-badge { color: var(--accent); border: 1px solid var(--accent); }
.tier-label { font-family: 'Press Start 2P', monospace; font-size: 11px; color: var(--text); flex: 1; }
.tier-count { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--muted); }

.tier-courses { display: grid; grid-template-columns: repeat(2, 1fr); }
.course-card {
  display: flex; gap: 14px; padding: 18px 22px;
  border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
  background: var(--card); text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
  align-items: flex-start;
}
.course-card:nth-child(even) { border-right: none; }
.course-card:nth-last-child(-n+2) { border-bottom: none; }
.course-card:hover:not(.coming-soon) { background: var(--surface); border-color: var(--border2); }
.course-card.coming-soon { opacity: 0.6; cursor: default; }

.course-num { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--muted); flex-shrink: 0; padding-top: 2px; width: 20px; }
.course-body { flex: 1; min-width: 0; }
.course-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.course-desc { font-size: 11px; color: var(--text2); line-height: 1.5; margin-bottom: 8px; }
.course-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
.course-time { font-size: 10px; color: var(--muted); }
.course-d0 { font-family: 'Space Mono', monospace; font-size: 9px; color: var(--accent); background: rgba(172,170,255,0.08); padding: 2px 5px; border-radius: 2px; }
.course-status { font-family: 'Space Mono', monospace; font-size: 11px; flex-shrink: 0; margin-top: 2px; }
.course-status.available { color: var(--accent); font-size: 14px; }
.course-status.coming-soon { font-size: 9px; color: var(--muted); border: 1px solid var(--border); padding: 3px 6px; border-radius: 3px; }

@media (max-width: 600px) {
  .tier-courses { grid-template-columns: 1fr; }
  .course-card { border-right: none !important; }
  .course-card:last-child { border-bottom: none; }
}
</style>
