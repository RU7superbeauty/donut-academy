---
import BaseLayout from '../../layouts/BaseLayout.astro';

const steps = [
  {
    num: '01',
    title: 'Install D0',
    time: '2 min',
    desc: 'D0 通过 GitHub Packages 分发（私有 Beta，需要 DonutLabs-ai 组织成员资格）。',
    blocks: [
      {
        label: '配置 npm registry',
        code: `# ~/.npmrc 中添加
@donutlabs-ai:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=\${GITHUB_TOKEN}`,
        copy: null,
      },
      {
        label: '全局安装',
        code: 'npm install -g @donutlabs-ai/d0-cli',
        copy: 'npm install -g @donutlabs-ai/d0-cli',
      },
      {
        label: '验证安装',
        code: 'd0 --version',
        copy: 'd0 --version',
        output: 'd0-cli v1.x.x · 169 tools available',
      },
    ],
  },
  {
    num: '02',
    title: 'Authenticate',
    time: '1 min',
    desc: 'D0 使用浏览器 OAuth 登录（Turnkey 云端密钥托管）。一次登录，所有操作全部解锁。',
    blocks: [
      {
        label: '浏览器登录',
        code: 'd0 login',
        copy: 'd0 login',
        output: '✓ Browser opened — complete login...\n✓ Authenticated · Turnkey wallet ready\n  Address: 0x742d...a8f9 (Arbitrum)',
      },
      {
        label: '验证身份',
        code: 'd0 auth status',
        copy: 'd0 auth status',
        output: '✓ Logged in · Session valid',
      },
    ],
  },
  {
    num: '03',
    title: 'Explore Markets',
    time: '5 min',
    desc: '现在你可以查询行情、技术分析、持仓数据。这些是 D0 的读操作——探索市场的入口。',
    blocks: [
      {
        label: '实时价格',
        code: 'd0 price ETH',
        copy: 'd0 price ETH',
        output: 'ETH/USDC   $3,247.50   +2.3% 24h   Vol $18.2B',
      },
      {
        label: '技术分析',
        code: 'd0 ta BTC',
        copy: 'd0 ta BTC',
        output: 'BTC/USDC $84,200\nRSI(14): 34.2  →  oversold territory\nMACD:     bullish crossover forming\nSignal:   LONG  (confidence: 62%)',
      },
      {
        label: '查询余额',
        code: 'd0 balance',
        copy: 'd0 balance',
        output: 'Wallet:       $0.00 USDC\nHyperLiquid:  $0.00 USDC (deposit to trade)\nPerps:        — not configured',
      },
    ],
  },
  {
    num: '04',
    title: 'Fund & First Trade',
    time: '10 min',
    desc: '充值到 HyperLiquid 账户，然后执行你的第一笔 Agent-Native 交易。',
    blocks: [
      {
        label: '获取 HL 钱包地址（充值用）',
        code: 'd0 hl wallet',
        copy: 'd0 hl wallet',
        output: '✓ HyperLiquid wallet\n  Address: 0x742d...a8f9  (Arbitrum)\n  Transfer USDC to this address to fund your account',
      },
      {
        label: '充值后查看余额',
        code: 'd0 hl:balance',
        copy: 'd0 hl:balance',
        output: 'Available:  $100.00 USDC\nIn orders:  $0.00\nTotal:      $100.00 USDC',
      },
      {
        label: '设置杠杆（可选，默认1x）',
        code: 'd0 hl:leverage ETH 3',
        copy: 'd0 hl:leverage ETH 3',
        output: '✓ Leverage set: ETH × 3',
      },
      {
        label: '第一笔交易 — 限价买入',
        code: 'd0 hl:limit buy ETH 0.01 3200',
        copy: 'd0 hl:limit buy ETH 0.01 3200',
        output: '✓ Order placed\n  Side:  BUY  ETH-PERP\n  Size:  0.01 ETH\n  Price: $3,200.00 (limit)\n  ID:    order_8f4a2c...',
      },
      {
        label: '查看持仓',
        code: 'd0 hl:positions',
        copy: 'd0 hl:positions',
        output: 'ETH-PERP  LONG  0.01 ETH\n  Entry:   $3,200.40\n  Mark:    $3,247.50\n  PnL:     +$0.47  (+1.47%)',
      },
    ],
  },
  {
    num: '05',
    title: 'Risk Management',
    time: '5 min',
    desc: '每笔仓位都需要止损。这不是可选项。',
    blocks: [
      {
        label: '设置止损（-5%）',
        code: 'd0 hl:stop-loss ETH 0.01 3040',
        copy: 'd0 hl:stop-loss ETH 0.01 3040',
        output: '✓ Stop-loss set\n  Trigger: $3,040.00 (-5%)\n  Action:  market close 0.01 ETH',
      },
      {
        label: '平仓',
        code: 'd0 hl:close ETH',
        copy: 'd0 hl:close ETH',
        output: '✓ Position closed\n  ETH-PERP LONG 0.01 ETH\n  Exit:  $3,251.20\n  PnL:   +$0.51 realized',
      },
    ],
  },
];
---
<BaseLayout title="Quick Start — D0 in 30 Minutes" description="Install D0, authenticate, explore markets, and execute your first trade in 30 minutes.">

<!-- Breadcrumb -->
<nav class="breadcrumb">
  <a href="/learn/">LEARN</a>
  <span>›</span>
  <span>Quick Start</span>
</nav>

<!-- Header -->
<section class="qs-header">
  <div class="qs-badge">⚡ START HERE</div>
  <h1 class="qs-title">Quick Start</h1>
  <p class="qs-subtitle">From install to first trade in 30 minutes.</p>
  <div class="qs-meta-row">
    <span class="qs-meta-item">⏱ ~30 minutes total</span>
    <span class="qs-meta-item">🎯 5 steps</span>
    <span class="qs-meta-item">📦 Requires: Private Beta access</span>
  </div>
</section>

<!-- Progress -->
<div class="progress-bar">
  <div class="progress-inner">
    {steps.map((s, i) => (
      <div class="progress-step">
        <div class="ps-num">{s.num}</div>
        <div class="ps-title">{s.title}</div>
        <div class="ps-time">{s.time}</div>
        {i < steps.length - 1 && <div class="ps-line"></div>}
      </div>
    ))}
  </div>
</div>

<!-- Steps -->
<div class="steps-container">
  {steps.map(step => (
    <section class="step-section" id={`step-${step.num}`}>
      <div class="step-header">
        <div class="step-num-badge">{step.num}</div>
        <div>
          <h2 class="step-title">{step.title}</h2>
          <span class="step-time">⏱ {step.time}</span>
        </div>
      </div>
      <p class="step-desc">{step.desc}</p>

      <div class="code-blocks">
        {step.blocks.map(block => (
          <div class="code-block-wrap">
            {block.label && <div class="code-label">{block.label}</div>}
            <div class="code-box">
              <div class="code-top">
                <pre class="code-pre"><code>{block.code}</code></pre>
                {block.copy && (
                  <button class="copy-btn" data-copy={block.copy}>COPY</button>
                )}
              </div>
              {block.output && (
                <div class="code-output">
                  <div class="output-label">OUTPUT</div>
                  <pre class="output-pre">{block.output}</pre>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  ))}
</div>

<!-- Next Steps -->
<section class="next-section">
  <h2 class="next-title">What's Next?</h2>
  <div class="next-grid">
    <a href="/playbook/funding-rate-arb/" class="next-card">
      <div class="next-icon">⚡</div>
      <div class="next-label">PLAYBOOK</div>
      <div class="next-name">Funding Rate Arbitrage</div>
      <p class="next-desc">用资金费率偏离赚取持续收益。完整 D0 实现。</p>
    </a>
    <a href="/research/dr-001-intent-parsing/" class="next-card">
      <div class="next-icon">🔬</div>
      <div class="next-label">RESEARCH</div>
      <div class="next-name">DR-001: Intent Parsing</div>
      <p class="next-desc">理解 AI Agent 如何解析模糊交易意图。</p>
    </a>
    <a href="/learn/" class="next-card">
      <div class="next-icon">📚</div>
      <div class="next-label">CURRICULUM</div>
      <div class="next-name">Tier 1 — Intro Course</div>
      <p class="next-desc">系统学习加密交易基础，配合 D0 实战。</p>
    </a>
  </div>
</section>

</BaseLayout>

<script>
document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const text = (btn as HTMLButtonElement).dataset.copy || '';
    navigator.clipboard.writeText(text).then(() => {
      btn.textContent = 'COPIED!';
      setTimeout(() => { btn.textContent = 'COPY'; }, 1500);
    });
  });
});
</script>

<style>
.breadcrumb {
  max-width: var(--content-w);
  margin: 0 auto;
  padding: 24px 24px 0;
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--muted);
}
.breadcrumb a { color: var(--accent); text-decoration: none; }
.breadcrumb a:hover { color: var(--accent2); }

.qs-header {
  max-width: var(--content-w);
  margin: 0 auto;
  padding: 32px 24px 48px;
}
.qs-badge {
  display: inline-block;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  color: #131320;
  background: var(--accent);
  padding: 4px 12px;
  border-radius: 3px;
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}
.qs-title {
  font-family: 'Press Start 2P', monospace;
  font-size: clamp(20px, 3vw, 32px);
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 12px;
}
.qs-subtitle { font-size: 16px; color: var(--text2); line-height: 1.6; margin-bottom: 20px; }
.qs-meta-row { display: flex; gap: 20px; flex-wrap: wrap; }
.qs-meta-item {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  color: var(--text2);
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 5px 12px;
  border-radius: 4px;
}

/* Progress bar */
.progress-bar {
  max-width: var(--content-w);
  margin: 0 auto;
  padding: 0 24px 48px;
}
.progress-inner {
  display: flex;
  align-items: flex-start;
  gap: 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px 24px;
  overflow-x: auto;
}
.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  position: relative;
  flex: 1;
  min-width: 80px;
}
.ps-num {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  font-weight: 700;
  color: #131320;
  background: var(--accent);
  width: 28px;
  height: 28px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ps-title { font-size: 11px; font-weight: 700; color: var(--text); text-align: center; }
.ps-time { font-size: 10px; color: var(--muted); font-family: 'Space Mono', monospace; }
.ps-line {
  position: absolute;
  top: 14px;
  left: calc(50% + 14px);
  right: calc(-50% + 14px);
  height: 1px;
  background: var(--border2);
}

/* Steps */
.steps-container {
  max-width: var(--content-w);
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 56px;
}
.step-section { scroll-margin-top: 80px; }
.step-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 12px;
}
.step-num-badge {
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  font-weight: 700;
  color: #131320;
  background: var(--accent);
  padding: 4px 10px;
  border-radius: 4px;
  flex-shrink: 0;
  margin-top: 2px;
}
.step-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 16px;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 4px;
}
.step-time {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
}
.step-desc { font-size: 14px; color: var(--text2); line-height: 1.8; margin-bottom: 20px; }

/* Code blocks */
.code-blocks { display: flex; flex-direction: column; gap: 12px; }
.code-block-wrap { display: flex; flex-direction: column; gap: 4px; }
.code-label {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.5px;
}
.code-box {
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}
.code-top {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  background: #0d0d1a;
  padding: 16px 20px;
}
.code-pre {
  flex: 1;
  font-family: 'Space Mono', monospace;
  font-size: 13px;
  color: var(--text);
  white-space: pre-wrap;
  word-break: break-all;
  margin: 0;
  line-height: 1.6;
}
.copy-btn {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  color: var(--accent);
  background: transparent;
  border: 1px solid var(--border2);
  border-radius: 3px;
  padding: 4px 8px;
  cursor: pointer;
  flex-shrink: 0;
  margin-top: 2px;
  transition: all 0.15s;
}
.copy-btn:hover { background: rgba(172,170,255,0.1); }
.code-output {
  background: var(--surface);
  border-top: 1px solid var(--border);
  padding: 12px 20px;
}
.output-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 1px;
  margin-bottom: 8px;
}
.output-pre {
  font-family: 'Space Mono', monospace;
  font-size: 12px;
  color: var(--text2);
  white-space: pre-wrap;
  margin: 0;
  line-height: 1.7;
}

/* Next steps */
.next-section {
  max-width: var(--content-w);
  margin: 0 auto;
  padding: 64px 24px 80px;
}
.next-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: var(--text);
  margin-bottom: 24px;
}
.next-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.next-card {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 24px 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  text-decoration: none;
  transition: border-color 0.15s, transform 0.15s;
}
.next-card:hover { border-color: var(--accent); transform: translateY(-2px); }
.next-icon { font-size: 24px; }
.next-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--accent);
}
.next-name { font-size: 13px; font-weight: 700; color: var(--text); line-height: 1.4; }
.next-desc { font-size: 12px; color: var(--text2); line-height: 1.6; }

@media (max-width: 600px) {
  .next-grid { grid-template-columns: 1fr; }
  .progress-inner { gap: 0; }
  .ps-line { display: none; }
}
</style>
