---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: Lang;
}
const {
  title = 'Donut Academy',
  description = 'AI-Native Crypto Trading Infrastructure',
  ogImage = '/logo.png',
  lang = defaultLang,
} = Astro.props;

const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems = [
  { href: `/${lang}/learn/`, label: t('nav.learn') },
  { href: `/${lang}/playbook/`, label: t('nav.playbook') },
  { href: `/${lang}/research/`, label: t('nav.research') },
  { href: `/${lang}/updates/`, label: t('nav.updates') },
];

const footerLearn = [
  { href: `/${lang}/learn/`, label: 'Overview' },
  { href: `/${lang}/learn/quickstart/`, label: 'Quick Start' },
];
const footerPlaybook = [
  { href: `/${lang}/playbook/`, label: t('nav.playbook') },
  { href: `/${lang}/playbook/funding-rate-arb/`, label: 'Funding Rate Arb' },
  { href: `/${lang}/playbook/whale-monitor/`, label: 'Whale Monitor' },
  { href: `/${lang}/playbook/mm-detection/`, label: 'MM Detection' },
];
const footerResearch = [
  { href: `/${lang}/research/`, label: t('nav.research') },
  { href: `/${lang}/articles/dr-001-intent-parsing/`, label: 'DR-001' },
  { href: `/${lang}/articles/dr-002-cross-protocol-semantics/`, label: 'DR-002' },
  { href: `/${lang}/articles/dr-003-risk-failure-modes/`, label: 'DR-003' },
  { href: `/${lang}/articles/dr-004-multi-agent-game-theory/`, label: 'DR-004' },
  { href: `/${lang}/articles/dr-005-mm-pattern-detection/`, label: 'DR-005' },
];
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Donut Academy</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/logo.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Noto+Sans+SC:wght@400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <a href={`/${lang}/`} class="logo">
      <img src="/logo.png" alt="Donut" class="logo-img" />
      <span class="logo-text">DONUT <em>ACADEMY</em></span>
    </a>

    <nav class="nav-links" role="navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`nav-link ${currentPath.startsWith(item.href) ? 'active' : ''}`}
        >
          {item.label}
        </a>
      ))}
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </nav>

    <div class="nav-cta">
      <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank" rel="noopener" class="btn-cta">
        {t('nav.get_d0')} <span class="cta-arrow">→</span>
      </a>
    </div>

    <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link">{item.label}</a>
    ))}
    <div class="mobile-nav-link" style="display:flex;gap:8px;padding:12px 24px">
      <LanguageSwitcher lang={lang} currentPath={currentPath} />
    </div>
    <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank" class="mobile-nav-link cta">{t('nav.get_d0')} →</a>
  </div>
</header>

<main>
  <slot />
</main>

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={`/${lang}/`} class="footer-logo">DONUT <span>ACADEMY</span></a>
      <p class="footer-tagline">{t('footer.tagline')}</p>
      <div class="footer-socials">
        <a href="https://github.com/DonutLabs-ai" target="_blank" aria-label="GitHub">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://twitter.com/DonutLabsAI" target="_blank" aria-label="Twitter">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <h4>{t('nav.learn')}</h4>
        {footerLearn.map(l => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-col">
        <h4>{t('nav.playbook')}</h4>
        {footerPlaybook.map(l => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-col">
        <h4>{t('nav.research')}</h4>
        {footerResearch.map(l => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="footer-col">
        <h4>D0 CLI</h4>
        <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank">Install D0</a>
        <a href={`/${lang}/updates/`}>{t('nav.updates')}</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>{t('footer.rights')}</span>
    <span class="footer-disclaimer">NFA / DYOR / For educational purposes only.</span>
  </div>
</footer>

<script>
  const btn = document.getElementById('hamburgerBtn');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('open');
    btn.classList.toggle('open');
  });
</script>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
