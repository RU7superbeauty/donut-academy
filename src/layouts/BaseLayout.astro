---
interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Donut Academy',
  description = 'AI-Native Crypto Trading Infrastructure — Learn D0, build autonomous trading agents.',
  ogImage = '/logo.png'
} = Astro.props;

const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/learn/', label: 'LEARN', i18n: 'nav.learn' },
  { href: '/playbook/', label: 'PLAYBOOK', i18n: 'nav.playbook' },
  { href: '/research/', label: 'RESEARCH', i18n: 'nav.research' },
  { href: '/updates/', label: 'UPDATES', i18n: 'nav.updates' },
  { href: '/arcade/', label: 'ARCADE', i18n: 'nav.arcade' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Donut Academy</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="/logo.png" type="image/png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Noto+Sans+SC:wght@400;500;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
</head>
<body>

<!-- Top Nav -->
<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="logo">
      <img src="/logo.png" alt="Donut" class="logo-img" />
      <span class="logo-text">DONUT <em>ACADEMY</em></span>
    </a>

    <nav class="nav-links" role="navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`nav-link ${currentPath.startsWith(item.href) ? 'active' : ''}`}
          data-i18n={item.i18n}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="lang-switcher" id="langSwitcher">
      <button class="lang-btn" id="langBtn" aria-label="Language">
        <span id="langLabel">EN</span>
        <span class="lang-arrow">▾</span>
      </button>
      <div class="lang-dropdown" id="langDropdown">
        <button class="lang-option" data-lang="en">EN — English</button>
        <button class="lang-option" data-lang="zh-CN">简中 — 简体中文</button>
        <button class="lang-option" data-lang="zh-TW">繁中 — 繁體中文</button>
        <button class="lang-option" data-lang="ko">한국어 — Korean</button>
        <button class="lang-option" data-lang="ja">日本語 — Japanese</button>
      </div>
    </div>

    <div class="nav-cta">
      <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank" rel="noopener" class="btn-cta">
        <span data-i18n="nav.getD0">GET D0</span> <span class="cta-arrow">→</span>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburgerBtn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobileMenu">
    {navItems.map(item => (
      <a href={item.href} class="mobile-nav-link" data-i18n={item.i18n}>{item.label}</a>
    ))}
    <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank" class="mobile-nav-link cta" data-i18n="nav.getD0">GET D0 →</a>
    <div class="mobile-lang-switcher">
      <button class="mobile-lang-option" data-lang="en">EN</button>
      <button class="mobile-lang-option" data-lang="zh-CN">简中</button>
      <button class="mobile-lang-option" data-lang="zh-TW">繁中</button>
      <button class="mobile-lang-option" data-lang="ko">한국</button>
      <button class="mobile-lang-option" data-lang="ja">日本</button>
    </div>
  </div>
</header>

<!-- Page Content -->
<main>
  <slot />
</main>

<!-- Footer -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">DONUT <span>ACADEMY</span></a>
      <p class="footer-tagline" data-i18n="footer.tagline">AI-Native Crypto Trading Infrastructure.<br>Less GUI. More Agent.</p>
      <div class="footer-socials">
        <a href="https://github.com/DonutLabs-ai" target="_blank" aria-label="GitHub">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://twitter.com/DonutLabsAI" target="_blank" aria-label="Twitter">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    </div>

    <div class="footer-cols">
      <div class="footer-col">
        <h4 data-i18n="footer.learn">LEARN</h4>
        <a href="/learn/" data-i18n="footer.overview">Overview</a>
        <a href="/learn/quickstart/" data-i18n="footer.quickstart">Quick Start</a>
        <a href="/learn/tier-1/" data-i18n="footer.tier1">Tier 1 — Intro</a>
        <a href="/learn/tier-2/" data-i18n="footer.tier2">Tier 2 — Advanced</a>
        <a href="/learn/tier-3/" data-i18n="footer.tier3">Tier 3 — Frontier</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.playbook">PLAYBOOK</h4>
        <a href="/playbook/" data-i18n="footer.allWorkflows">All Workflows</a>
        <a href="/playbook/funding-rate-arb/" data-i18n="footer.fundingRateArb">Funding Rate Arb</a>
        <a href="/playbook/whale-monitor/" data-i18n="footer.whaleMonitor">Whale Monitor</a>
        <a href="/playbook/mm-detection/" data-i18n="footer.mmDetection">MM Detection</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.research">RESEARCH</h4>
        <a href="/research/" data-i18n="footer.allPapers">All Papers</a>
        <a href="/articles/dr-001-intent-parsing/">DR-001 Intent Parsing</a>
        <a href="/articles/dr-002-cross-protocol-semantics/">DR-002 Cross-Protocol</a>
        <a href="/articles/dr-003-risk-failure-modes/">DR-003 Risk Failure</a>
        <a href="/articles/dr-004-multi-agent-game-theory/">DR-004 Game Theory</a>
        <a href="/articles/dr-005-mm-pattern-detection/">DR-005 MM Detection</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.d0cli">D0 CLI</h4>
        <a href="https://github.com/DonutLabs-ai/d0-cli" target="_blank" data-i18n="footer.installD0">Install D0</a>
        <a href="/updates/" data-i18n="footer.changelog">Changelog</a>
        <a href="/articles/agentic-trading-stack/" data-i18n="footer.architecture">Architecture</a>
        <a href="/articles/d0-design-principles/" data-i18n="footer.designPrinciples">Design Principles</a>
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.community">COMMUNITY</h4>
        <a href="https://discord.com/invite/donut-ai" target="_blank" data-i18n="footer.discord">Discord</a>
        <a href="https://t.me/DonutAIOfficial" target="_blank" data-i18n="footer.telegram">Telegram</a>
        <a href="https://beta.donutbrowser.ai" target="_blank" data-i18n="footer.hilBeta">Donut HIL Beta</a>
        <a href="https://docs.donutbrowser.ai" target="_blank" data-i18n="footer.donutDocs">Donut Docs</a>
        <a href="https://docs-d0.donutbrowser.ai" target="_blank" data-i18n="footer.d0cliDocs">D0 CLI Docs</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span data-i18n="footer.copyright">© 2026 DonutLabs. All rights reserved.</span>
    <span class="footer-disclaimer" data-i18n="footer.disclaimer">NFA / DYOR / For educational purposes only.</span>
  </div>
</footer>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('hamburgerBtn');
  const menu = document.getElementById('mobileMenu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('open');
    btn.classList.toggle('open');
  });

  // ─── i18n System ───
  (function() {
    const LANGS = ['en', 'zh-CN', 'zh-TW', 'ko', 'ja'];
    const LANG_LABELS: Record<string, string> = { en: 'EN', 'zh-CN': '简中', 'zh-TW': '繁中', ko: '한국어', ja: '日本語' };
    let currentLang = 'en';
    let translations: Record<string, Record<string, string>> = {};

    // Load translations lazily
    async function loadTranslations() {
      const mod = await import('../i18n/translations');
      translations = mod.translations;
    }

    function detectLang(): string {
      const saved = localStorage.getItem('da-lang');
      if (saved && LANGS.includes(saved)) return saved;
      const nav = navigator.language || 'en';
      if (nav.startsWith('zh')) {
        return nav.includes('TW') || nav.includes('HK') || nav.includes('Hant') ? 'zh-TW' : 'zh-CN';
      }
      for (const l of LANGS) {
        if (nav.startsWith(l)) return l;
      }
      return 'en';
    }

    function applyLang(lang: string) {
      currentLang = lang;
      localStorage.setItem('da-lang', lang);
      const dict = translations[lang] || translations['en'];
      if (!dict) return;
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (key && dict[key]) {
          // Preserve HTML structure for elements with newlines in translation
          const val = dict[key];
          if (val.includes('\n')) {
            el.innerHTML = val.replace(/\n/g, '<br>');
          } else {
            el.textContent = val;
          }
        }
      });
      // Update lang label
      const label = document.getElementById('langLabel');
      if (label) label.textContent = LANG_LABELS[lang] || 'EN';
      // Update active state in dropdown + mobile
      document.querySelectorAll('.lang-option').forEach(opt => {
        opt.classList.toggle('active', (opt as HTMLElement).dataset.lang === lang);
      });
      document.querySelectorAll('.mobile-lang-option').forEach(opt => {
        opt.classList.toggle('active', (opt as HTMLElement).dataset.lang === lang);
      });
      document.documentElement.lang = lang === 'zh-CN' ? 'zh-CN' : lang === 'zh-TW' ? 'zh-TW' : lang;
    }

    // Language switcher dropdown
    const langBtn = document.getElementById('langBtn');
    const langDropdown = document.getElementById('langDropdown');
    langBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      langDropdown?.classList.toggle('open');
    });
    document.addEventListener('click', () => {
      langDropdown?.classList.remove('open');
    });
    document.querySelectorAll('.lang-option').forEach(opt => {
      opt.addEventListener('click', (e) => {
        e.stopPropagation();
        const lang = (opt as HTMLElement).dataset.lang || 'en';
        applyLang(lang);
        langDropdown?.classList.remove('open');
      });
    });

    // Mobile language switcher
    document.querySelectorAll('.mobile-lang-option').forEach(opt => {
      opt.addEventListener('click', () => {
        const lang = (opt as HTMLElement).dataset.lang || 'en';
        applyLang(lang);
        // Update mobile active states
        document.querySelectorAll('.mobile-lang-option').forEach(o => {
          o.classList.toggle('active', (o as HTMLElement).dataset.lang === lang);
        });
      });
    });

    // Initialize
    loadTranslations().then(() => {
      const lang = detectLang();
      applyLang(lang);
    });
  })();
</script>

</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* ─── Topbar ─── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 200;
    background: rgba(13,13,22,0.92);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .topbar-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    border-radius: 6px;
  }
  .logo-text {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    letter-spacing: 1.5px;
    color: var(--accent);
    white-space: nowrap;
  }
  .logo-text em {
    color: var(--text);
    font-style: normal;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  .nav-link {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.8px;
    color: var(--text2);
    text-decoration: none;
    padding: 7px 12px;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-link:hover { color: var(--text); background: rgba(172,170,255,0.07); }
  .nav-link.active { color: var(--accent); }
  .nav-cta { flex-shrink: 0; }
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: #131320;
    background: var(--accent);
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .btn-cta:hover { background: var(--accent2); transform: translateY(-1px); }
  .cta-arrow { font-size: 13px; }

  /* Language Switcher */
  .lang-switcher {
    position: relative;
    flex-shrink: 0;
  }
  .lang-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text2);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 5px 10px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .lang-btn:hover { color: var(--accent); border-color: var(--accent); }
  .lang-arrow { font-size: 8px; }
  .lang-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 0;
    min-width: 160px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
    z-index: 300;
  }
  .lang-dropdown.open { display: block; }
  .lang-option {
    display: block;
    width: 100%;
    text-align: left;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--text2);
    background: transparent;
    border: none;
    padding: 8px 14px;
    cursor: pointer;
    transition: all 0.1s;
  }
  .lang-option:hover { color: var(--text); background: rgba(172,170,255,0.08); }
  .lang-option.active { color: var(--accent); }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text2);
    border-radius: 2px;
    transition: all 0.2s;
  }
  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  .mobile-menu {
    display: none;
    flex-direction: column;
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 8px 0;
  }
  .mobile-menu.open { display: flex; }
  .mobile-nav-link {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.8px;
    color: var(--text2);
    text-decoration: none;
    padding: 12px 24px;
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav-link.cta { color: var(--accent); }
  .mobile-lang-switcher {
    display: flex;
    gap: 6px;
    padding: 12px 0 0;
    border-top: 1px solid var(--border);
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .mobile-lang-option {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: var(--text2);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 6px 12px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .mobile-lang-option:hover,
  .mobile-lang-option.active {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(172,170,255,0.08);
  }

  @media (max-width: 680px) {
    .nav-links, .nav-cta, .lang-switcher { display: none; }
    .hamburger { display: flex; }
  }

  /* ─── Footer ─── */
  .footer {
    margin-top: 96px;
    border-top: 1px solid var(--border);
    background: var(--surface);
  }
  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 56px 24px 48px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }
  .footer-brand { display: flex; flex-direction: column; gap: 12px; }
  .footer-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--accent);
    text-decoration: none;
  }
  .footer-logo span { color: var(--text); }
  .footer-tagline {
    font-size: 12px;
    color: var(--text2);
    line-height: 1.7;
  }
  .footer-socials { display: flex; gap: 12px; margin-top: 4px; }
  .footer-socials a { color: var(--text2); transition: color 0.15s; }
  .footer-socials a:hover { color: var(--accent); }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px;
  }
  .footer-col { display: flex; flex-direction: column; gap: 8px; }
  .footer-col h4 {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--accent);
    margin-bottom: 4px;
  }
  .footer-col a {
    font-size: 12px;
    color: var(--text2);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.4;
  }
  .footer-col a:hover { color: var(--text); }

  .footer-bottom {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
  }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr; gap: 32px; }
    .footer-cols { grid-template-columns: repeat(2, 1fr); }
    .footer-bottom { flex-direction: column; gap: 6px; text-align: center; }
  }
  @media (max-width: 480px) {
    .footer-cols { grid-template-columns: 1fr 1fr; }
  }
</style>
