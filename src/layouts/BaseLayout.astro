---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { type Lang, defaultLang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}
const { title = 'Donut Academy', description = 'AI-Native Crypto Trading Infrastructure', lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Noto+Sans+SC:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
  <nav class="topbar">
    <div class="topbar-inner">
      <a href={`/${lang}/`} class="logo">DONUT <span>ACADEMY</span></a>
      <div class="nav-links">
        <a href={`/${lang}/`}>{t('nav.home')}</a>
        <a href={`/${lang}/articles/`}>{t('nav.articles')}</a>
        <LanguageSwitcher lang={lang} currentPath={currentPath} />
      </div>
    </div>
  </nav>
  <div class="container">
    <slot />
    <div class="footer">
      <p style="font-family:'Press Start 2P',monospace;font-size:11px;letter-spacing:2px;color:var(--text2);margin-bottom:4px">DONUT ACADEMY</p>
      <p>{t('footer.tagline')}</p>
      <p style="margin-top:8px;font-family:'Space Mono',monospace">{t('footer.powered')}</p>
    </div>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
